# ── Database ──────────────────────────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL="file:./dev.db"
# Prod (PostgreSQL on Railway — copy the Railway-provided URL):
# DATABASE_URL="postgresql://user:password@host:5432/civic_db"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-32-char-secret-in-production"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
BCRYPT_ROUNDS="12"

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
CORS_ORIGIN="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
# Leave blank in dev — emails print to console instead
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@civicaccountability.app"

# ── Maps ──────────────────────────────────────────────────────────────────────
# Leave blank to use mock geocoding (Philadelphia center coords)
GOOGLE_MAPS_API_KEY=""
