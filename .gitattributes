# Normalize line endings across platforms
* text=auto

# Force Unix line endings for these file types
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.prisma text eol=lf
*.env.example text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.db binary
